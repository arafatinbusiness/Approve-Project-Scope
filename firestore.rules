rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAgency() {
      return isAuthenticated() && (
        request.auth.token.email == 'support@labinitial.com' ||
        request.auth.token.email == 'arafatinbusiness@gmail.com' ||
        request.auth.token.email == 'support@shopifyheroesagency.com' ||
        request.auth.token.email == 'arafat@labinitial.com' ||
        request.auth.token.email == 'arafat@shopifyheroesagency.com'
      );
    }

    function isProjectClient(projectId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/projects/$(projectId)).data.clientEmail == request.auth.token.email;
    }

    function isProjectCreator(projectId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/projects/$(projectId)).data.createdBy == request.auth.token.email;
    }

    // Projects collection
    match /projects/{projectId} {
      // Anyone can list/query projects by clientEmail (used for email registration check)
      // This only returns whether a document exists, not the actual data
      allow list: if true;
      
      // Agency can create projects
      allow create: if isAgency();
      
      // Agency can read all their projects, client can read projects assigned to them
      allow read: if isAgency() || 
        resource.data.clientEmail == request.auth.token.email;
      
      // Agency can update their own projects
      allow update: if isAgency() && 
        resource.data.createdBy == request.auth.token.email;
      
      // Only agency can delete
      allow delete: if isAgency() && 
        resource.data.createdBy == request.auth.token.email;

      // Subcollections if needed in future
      match /{document=**} {
        allow read, write: if isAgency() || 
          resource.data.clientEmail == request.auth.token.email;
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
